# ======================================
# OS-generated files (macOS, Windows, Linux)
# ======================================
.DS_Store
.AppleDouble
.LSOverride
._*                  # Resource fork files
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
Icon?
.nfs*

# ======================================
# Editor / IDE files
# ======================================
.vscode/
*.sublime-*

# ======================================
# RStudio / R
# ======================================
.Rproj.user/
.Rhistory
.RData
.Ruserdata

# R Project & Environment
.Renviron

# renv infrastructure (except lockfile)
renv/
!renv/activate.R
!renv/settings.json
!renv.lock

# ======================================
# Python
# ======================================
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# ======================================
# Quarto
# ======================================
.quarto/             # Quarto build cache
_site/               # Quarto site output
*.nb.html            # Quarto-generated notebook outputs
*.qmd~               # Temp swap files

# ======================================
# Output / Reports / Artifacts (custom)
# ======================================
output/
data/derived/
figures/
tables/
logs/
*.log
*.aux
*.out
*.toc
*.bbl
*.blg
